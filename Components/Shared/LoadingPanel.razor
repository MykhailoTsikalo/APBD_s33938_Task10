@if (IsLoading)
{
    <div class="my-3 text-secondary">
        <span class="spinner-border spinner-border-sm"></span> Loading data, please wait...
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}